# 信令服务器地址
# 开发环境默认: http://localhost:3000
# 生产环境示例: https://your-server.com
VITE_SIGNALING_SERVER=http://localhost:3000

# TURN 服务器（可选）
# 使用 Vite 环境变量：VITE_TURN_URL / VITE_TURN_USER / VITE_TURN_PASS
# TURN_URL 示例： turn:your-turn-server.com:3478
VITE_TURN_URL=
VITE_TURN_USER=
VITE_TURN_PASS=
# 注意：不要将真实凭证提交到公共仓库。

# NAT 类型检测服务（可选）。用于显示"本机/对方 NAT 类型"。
# 检测逻辑已原生实现在 server/src/natCheck.ts 里（需在信令服务器上设置 NAT_CHECK_MODE=primary），
# 这里填该信令服务器自己的公网地址，不需要另外部署 Python 工具。
# VITE_NAT_CHECK_URL 示例: http://your-signaling-server.com:8080
VITE_NAT_CHECK_URL=
# 双节点架构中 secondary 机器的主机名（可选，用于区分 Full/Address-Restricted/Port-Restricted 锥形子类型，
# 该机器需以 NAT_CHECK_MODE=secondary 启动同一个 server 包）
VITE_NAT_CHECK_SECONDARY_HOST=
