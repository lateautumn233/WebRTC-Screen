# 信令服务器地址
# 开发环境默认: http://localhost:3000
# 生产环境示例: https://your-server.com
VITE_SIGNALING_SERVER=http://localhost:3000

# TURN 服务器（可选）
# 使用 Vite 环境变量：VITE_TURN_URL / VITE_TURN_USER / VITE_TURN_PASS
# TURN_URL 示例： turn:your-turn-server.com:3478
VITE_TURN_URL=
VITE_TURN_USER=
VITE_TURN_PASS=
# 注意：不要将真实凭证提交到公共仓库。

# NAT 类型检测服务（可选）。用于显示"本机/对方 NAT 类型"。
# 需自行部署双服务器架构的检测工具：https://github.com/lateautumn233/webrtc_check_nat
# VITE_NAT_CHECK_URL 示例: http://your-nat-check-server.com:8080
VITE_NAT_CHECK_URL=
# 双节点架构中第二台服务器的主机名（可选，用于区分 Full/Address-Restricted/Port-Restricted 锥形子类型）
VITE_NAT_CHECK_SECONDARY_HOST=
